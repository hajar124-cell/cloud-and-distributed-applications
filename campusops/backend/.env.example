# ===========================
# CampusOps Backend - .env
# Université Euromed de Fès
# ===========================

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://campusops:campusops_secret@localhost:5432/campusops_db

# JWT
JWT_SECRET=campusops_jwt_secret_change_in_production_min_32_chars
JWT_REFRESH_SECRET=campusops_refresh_secret_change_in_production
JWT_EXPIRES_IN=2h
REFRESH_EXPIRES_IN=7d

# Email SMTP (envoi)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_app_password_gmail

# Email IMAP (lecture)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=votre.email@gmail.com
IMAP_PASS=votre_app_password_gmail

# Telegram Bot
TELEGRAM_BOT_TOKEN=votre_token_botfather

# OpenClaw
OPENCLAW_SECRET=openclaw_webhook_secret_change_in_production

# Logs
LOG_LEVEL=info
